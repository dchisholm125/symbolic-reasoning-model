<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SRM vs Traditional LLM Benchmark</title>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #0f172a;
            color: #f8fafc;
        }

        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .typing-indicator::after {
            content: '▋';
            animation: blink 1s step-start infinite;
        }

        @keyframes blink {
            50% {
                opacity: 0;
            }
        }

        /* Heartbeat Animation */
        .heartbeat {
            display: inline-block;
            position: relative;
            width: 80px;
            height: 20px;
        }

        .heartbeat div {
            position: absolute;
            top: 8px;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: currentColor;
            animation-timing-function: cubic-bezier(0, 1, 1, 0);
        }

        .heartbeat div:nth-child(1) {
            left: 8px;
            animation: heartbeat1 0.6s infinite;
        }

        .heartbeat div:nth-child(2) {
            left: 8px;
            animation: heartbeat2 0.6s infinite;
        }

        .heartbeat div:nth-child(3) {
            left: 32px;
            animation: heartbeat2 0.6s infinite;
        }

        .heartbeat div:nth-child(4) {
            left: 56px;
            animation: heartbeat3 0.6s infinite;
        }

        @keyframes heartbeat1 {
            0% {
                transform: scale(0);
            }

            100% {
                transform: scale(1);
            }
        }

        @keyframes heartbeat3 {
            0% {
                transform: scale(1);
            }

            100% {
                transform: scale(0);
            }
        }

        @keyframes heartbeat2 {
            0% {
                transform: translate(0, 0);
            }

            100% {
                transform: translate(24px, 0);
            }
        }
    </style>
</head>

<body class="min-h-screen flex flex-col items-center p-6 font-sans">

    <div id="app" class="w-full max-w-6xl flex flex-col h-[90vh]">

        <!-- Header -->
        <header class="text-center mb-8">
            <h1 class="text-4xl font-bold tracking-tight text-white mb-2">Neuro-Symbolic Reasoning <span
                    class="text-blue-500">vs</span> Traditional LLMs</h1>
            <p class="text-slate-400">Live latency and quality A/B testing harness.</p>
        </header>

        <!-- The Arena (Side by Side Windows) -->
        <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">

            <!-- Traditional Window -->
            <div class="glass-panel rounded-2xl flex flex-col overflow-hidden shadow-2xl">
                <div class="bg-slate-800/80 px-4 py-3 border-b border-slate-700 flex justify-between items-center">
                    <div class="flex items-center space-x-2">
                        <div class="w-3 h-3 rounded-full bg-red-500"></div>
                        <span class="font-semibold text-slate-200">Traditional Agent (LangChain)</span>
                    </div>
                    <span class="text-xs font-mono text-slate-400">Context: ~2,400 Tokens</span>
                </div>
                <div class="p-6 flex-1 overflow-y-auto space-y-4 font-mono text-sm" id="trad-box">
                    <!-- Status Header -->
                    <div class="flex items-center justify-between mb-2">
                        <div v-if="isTradLoading" class="text-red-400 font-bold tabular-nums">CRUNCHING... {{
                            tradElapsedTime.toFixed(2) }}s</div>
                        <div v-else-if="tradResponse" class="text-red-400 font-bold tabular-nums">LATENCY: {{
                            (tradLatency || tradElapsedTime).toFixed(2) }}s</div>
                    </div>

                    <div v-if="isTradLoading" class="flex flex-col space-y-2">
                        <div class="text-slate-500 typing-indicator">Processing context...</div>
                    </div>

                    <div v-if="tradResponse" class="text-slate-300">
                        <div class="leading-relaxed whitespace-pre-wrap">{{ tradResponse }}</div>

                        <!-- Thinking Trace -->
                        <div v-if="tradDebug.length > 0" class="mt-6 pt-4 border-t border-slate-700/50">
                            <div class="text-[10px] text-slate-500 uppercase mb-2">Internal Thinking Trace</div>
                            <div
                                class="bg-black/30 p-3 rounded font-mono text-[10px] text-slate-400 overflow-x-auto max-h-32">
                                <div v-for="log in tradDebug" class="mb-1 text-red-300/60">{{ log }}</div>
                            </div>
                        </div>
                    </div>
                    <div v-else-if="!isTradLoading" class="text-slate-600 italic">Waiting for input...</div>
                </div>
            </div>

            <!-- SRM Window -->
            <div class="glass-panel rounded-2xl flex flex-col overflow-hidden shadow-2xl relative">
                <div class="absolute inset-0 bg-blue-500/5 pointer-events-none"></div>
                <div
                    class="bg-slate-800/80 px-4 py-3 border-b border-slate-700 flex justify-between items-center relative z-10">
                    <div class="flex items-center space-x-2">
                        <div class="w-3 h-3 rounded-full bg-blue-400 shadow-[0_0_10px_rgba(96,165,250,0.8)]"></div>
                        <span class="font-semibold text-white">SRM Framework (Layer 3)</span>
                    </div>
                    <span class="text-xs font-mono text-blue-300">Context: ~45 Tokens</span>
                </div>
                <div class="p-6 flex-1 overflow-y-auto space-y-4 font-mono text-sm relative z-10" id="srm-box">
                    <!-- Status Header -->
                    <div class="flex items-center justify-between mb-2">
                        <div v-if="isSrmLoading" class="text-blue-400 font-bold tabular-nums">PROCESSING... {{
                            srmElapsedTime.toFixed(2) }}s</div>
                        <div v-else-if="srmResponse" class="text-blue-400 font-bold tabular-nums">LATENCY: {{
                            (srmLatency || srmElapsedTime).toFixed(2) }}s</div>
                    </div>

                    <div v-if="isSrmLoading" class="flex flex-col space-y-2">
                        <div class="text-blue-400 typing-indicator">Reading symbol...</div>
                    </div>

                    <div v-if="srmResponse" class="text-slate-100">
                        <div class="leading-relaxed whitespace-pre-wrap">{{ srmResponse }}</div>

                        <!-- Thinking Trace -->
                        <div v-if="srmDebug.length > 0" class="mt-6 pt-4 border-t border-slate-700/50">
                            <div class="text-[10px] text-blue-500 uppercase mb-2">Symbolic Execution Trace</div>
                            <div
                                class="bg-black/30 p-3 rounded font-mono text-[10px] text-blue-300 overflow-x-auto max-h-32">
                                <div v-for="log in srmDebug" class="mb-1 text-blue-200/60">{{ log }}</div>
                            </div>
                        </div>
                    </div>
                    <div v-else-if="!isSrmLoading" class="text-slate-600 italic">Waiting for input...</div>
                </div>
            </div>

        </div>

        <!-- Message Bar -->
        <div class="w-full max-w-3xl mx-auto">
            <form @submit.prevent="sendMessage" class="relative flex items-center">
                <input v-model="userMessage" type="text" placeholder="Ask for a status update..."
                    class="w-full bg-slate-800 border border-slate-700 rounded-full py-4 pl-6 pr-16 text-slate-200 focus:outline-none focus:ring-2 focus:ring-blue-500 shadow-lg transition-all"
                    :disabled="isLoading">
                <button type="submit"
                    class="absolute right-2 bg-blue-600 hover:bg-blue-500 text-white rounded-full p-2 w-10 h-10 flex items-center justify-center transition-colors disabled:opacity-50"
                    :disabled="isLoading || !userMessage.trim()">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                        <path
                            d="M3.478 2.404a.75.75 0 0 0-.926.941l2.432 7.905H13.5a.75.75 0 0 1 0 1.5H4.984l-2.432 7.905a.75.75 0 0 0 .926.94 60.519 60.519 0 0 0 18.445-8.986.75.75 0 0 0 0-1.218A60.517 60.517 0 0 0 3.478 2.404Z" />
                    </svg>
                </button>
            </form>
        </div>

    </div>

    <script>
        const { createApp, ref } = Vue;

        createApp({
            setup() {
                const userMessage = ref('');
                const isLoading = ref(false);
                const isTradLoading = ref(false);
                const isSrmLoading = ref(false);
                const tradResponse = ref('');
                const tradLatency = ref(0);
                const srmResponse = ref('');
                const srmLatency = ref(0);
                const tradElapsedTime = ref(0);
                const srmElapsedTime = ref(0);
                const tradDebug = ref([]);
                const srmDebug = ref([]);
                let timerInterval = null;

                const consumeStream = async (url, message, responseRef, latencyRef, debugRef, loadingRef, timerRef) => {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message })
                    });

                    const reader = response.body.getReader();
                    const decoder = new TextDecoder();
                    let buffer = '';

                    while (true) {
                        const { value, done } = await reader.read();
                        if (done) break;

                        buffer += decoder.decode(value, { stream: true });
                        const lines = buffer.split('\n');
                        buffer = lines.pop();

                        for (const line of lines) {
                            if (line.startsWith('data: ')) {
                                try {
                                    const data = JSON.parse(line.slice(6));
                                    if (data.event === 'token') {
                                        responseRef.value += data.content;
                                    } else if (data.event === 'debug') {
                                        debugRef.value.push(data.content);
                                    } else if (data.event === 'done') {
                                        latencyRef.value = data.latency;
                                    }
                                } catch (e) {
                                    console.error("Error parsing stream line:", e);
                                }
                            }
                        }
                    }
                };

                const sendMessage = async () => {
                    if (!userMessage.value.trim()) return;

                    isLoading.value = true;
                    tradResponse.value = '';
                    srmResponse.value = '';
                    tradLatency.value = 0;
                    srmLatency.value = 0;
                    tradElapsedTime.value = 0;
                    srmElapsedTime.value = 0;
                    tradDebug.value = [];
                    srmDebug.value = [];

                    const message = userMessage.value;
                    userMessage.value = '';

                    // 1. Traditional Phase
                    isTradLoading.value = true;
                    const tradStartTime = Date.now();
                    timerInterval = setInterval(() => {
                        tradElapsedTime.value = (Date.now() - tradStartTime) / 1000;
                    }, 50);

                    try {
                        await consumeStream('http://localhost:8000/api/chat/traditional', message, tradResponse, tradLatency, tradDebug, isTradLoading, tradElapsedTime);
                    } catch (error) {
                        tradResponse.value = "Error connecting to backbone.";
                    } finally {
                        clearInterval(timerInterval);
                        isTradLoading.value = false;
                    }

                    // 2. SRM Phase
                    isSrmLoading.value = true;
                    const srmStartTime = Date.now();
                    timerInterval = setInterval(() => {
                        srmElapsedTime.value = (Date.now() - srmStartTime) / 1000;
                    }, 50);

                    try {
                        await consumeStream('http://localhost:8000/api/chat/srm', message, srmResponse, srmLatency, srmDebug, isSrmLoading, srmElapsedTime);
                    } catch (error) {
                        srmResponse.value = "Error connecting to backbone.";
                    } finally {
                        clearInterval(timerInterval);
                        isSrmLoading.value = false;
                        isLoading.value = false;
                    }
                };

                return { userMessage, isLoading, isTradLoading, isSrmLoading, tradResponse, tradLatency, srmResponse, srmLatency, tradElapsedTime, srmElapsedTime, tradDebug, srmDebug, sendMessage };
            }
        }).mount('#app');
    </script>
</body>

</html>