# ===========================================================================
# SRM LLM Backend Configuration
# ===========================================================================
# Copy this file to .env and fill in your values.
#
# BACKEND OPTIONS:
#   "openai_compat"  - Use any OpenAI-compatible API (OpenRouter, Groq, Together, Mistral, etc.)
#   "ollama"         - Use a local Ollama server (localhost:11434)
#   "llama_cpp"      - Direct GGUF loading via llama-cpp-python (desktop GPU branch only)
# ===========================================================================

LLM_BACKEND=openai_compat

# ---------------------------------------------------------------------------
# Option 1: OpenAI-Compatible API (OpenRouter, Groq, Together, etc.)
# ---------------------------------------------------------------------------
# OpenRouter (free tier models available):
#   URL: https://openrouter.ai/api/v1
#   Get key at: https://openrouter.ai/keys
#   Free models: deepseek/deepseek-r1-distill-llama-70b:free, meta-llama/llama-3.3-70b-instruct:free
#
# Groq (blazing fast, free tier):
#   URL: https://api.groq.com/openai/v1
#   Get key at: https://console.groq.com/keys  
#   Models: llama-3.3-70b-versatile, gemma2-9b-it
#
# Together AI (free credits):
#   URL: https://api.together.xyz/v1
#   Get key at: https://api.together.xyz/settings/api-keys
#   Models: meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
#
LLM_API_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek/deepseek-r1-distill-llama-70b:free

# ---------------------------------------------------------------------------
# Option 2: Ollama (local, no API key needed)
# ---------------------------------------------------------------------------
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull model: ollama pull qwen2.5:1.5b
# Then set LLM_BACKEND=ollama
#
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# ---------------------------------------------------------------------------
# Option 3: Direct llama_cpp (desktop GPU branch only)
# ---------------------------------------------------------------------------
# Requires: pip install llama-cpp-python
# Then set LLM_BACKEND=llama_cpp
#
GGUF_MODEL_PATH=./qwen2.5-0.5b-instruct-q4_k_m.gguf
